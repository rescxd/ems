<+>'use client';\r\n\r\nimport { useState } from 'react';\r\nimport { AnimatePresence, motion } from 'framer-motion';\r\nimport ContactForm from '@/components/common/footer/form/components/ContactForm';\r\nimport CallForm from '@/components/common/footer/form/components/CallForm';\r\nimport contactImage from '@/assets/common/contactImage.png';\r\nimport Image from 'next/image';\r\n\r\nconst tabs = [\r\n    { label: 'Formularz kontaktowy', component: <ContactForm /> },\r\n    { label: 'Umów rozmowę', component: <CallForm /> },\r\n];\r\n\r\nconst Form = () => {\r\n    const [activeIndex, setActiveIndex] = useState(0);\r\n\r\n    return (\r\n        <section id=\"kontakt\">\r\n            <div className=\"relative\">\r\n                <div className=\"absolute inset-0 z-10\">\r\n                    <Image\r\n                        src={contactImage}\r\n                        alt=\"\"\r\n                        className=\"object-cover\"\r\n                        fill\r\n                        sizes=\"100vw\"\r\n                        aria-hidden=\"true\"\r\n                    />\r\n                </div>\r\n                <div className=\"relative z-30 flex flex-col gap-[32px] md:gap-[40px] xl:gap-[56px]\">\r\n                    <div className=\"flex flex-col items-center gap-[22px]\">\r\n                        <div className=\"\">\r\n                            <p className=\"text-[#FFFFFFA6] text-[clamp(14px,2vw,16px)] font-normal grotesk leading-normal tracking-[0.32px] uppercase\">\r\n                                <span className=\"text-[#FFFFFF40] font-normal grotesk\">\r\n                                    //\r\n                                </span>{' '}\r\n                                Dowiedz się więcej\r\n                            </p>\r\n                        </div>\r\n                        <div className=\"\">\r\n                            <h2 className=\"text-[#FFFFFF] text-[clamp(24px,5vw,44px)] text-center grotesk font-medium leading-normal tracking-normal\">\r\n                                Skontaktuj się z nami\r\n                            </h2>\r\n                        </div>\r\n                        <div className=\"w-fit mx-auto p-[4px] bg-[#FFFFFF0D] flex items-center rounded-[4px]\">\r\n                            {tabs.map((tab, index) => (\r\n                                <div key={tab.label}>\r\n                                    <button\r\n                                        className={`cursor-pointer px-[18px] py-[7.5px] text-[#FFFFFF] text-[clamp(14px,2vw,17px)] font-medium grotesk leading-normal tracking-normal transition-all duration-200 ${\r\n                                            activeIndex === index\r\n                                                ? 'bg-[#FFFFFF1A] rounded-[3px]'\r\n                                                : 'hover:bg-[#FFFFFF0D] hover:rounded-[3px]'\r\n                                        }`}\r\n                                        onClick={() => setActiveIndex(index)}\r\n                                    >\r\n                                        {tab.label}\r\n                                    </button>\r\n                                </div>\r\n                            ))}\r\n                        </div>\r\n                    </div>\r\n                    <div className=\"overflow-hidden\">\r\n                        <AnimatePresence mode=\"wait\">\r\n                            <motion.div\r\n                                key={activeIndex}\r\n                                initial={{ opacity: 0, y: 20 }}\r\n                                animate={{ opacity: 1, y: 0 }}\r\n                                exit={{ opacity: 0, y: -20 }}\r\n                                transition={{\r\n                                    duration: 0.3,\r\n                                    ease: 'easeInOut',\r\n                                }}\r\n                            >\r\n                                {tabs[activeIndex].component}\r\n                            </motion.div>\r\n                        </AnimatePresence>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>\r\n    );\r\n};\r\n\r\nexport default Form;\r\n
